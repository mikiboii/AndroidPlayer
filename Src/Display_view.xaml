            <Border x:Name="ToastMessage"
                    IsHitTestVisible="False"
                    Background="#DD333333"
                    CornerRadius="8"
                    Padding="10,8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,20,0,0"
                    Opacity="0"
                    MaxWidth="400">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Icon -->
                        <ColumnDefinition Width="*" />   <!-- Text -->
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Image x:Name="Toasticon" Source="../../Icons/warning.png" 
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Width="30" Height="30"
                           VerticalAlignment="Top"
                           Margin="0,0,8,0"/>

                    <!-- Text -->
                    <TextBlock x:Name="ToastText"
                               Grid.Column="1"
                               Text="Saved successfully!"
                               Foreground="White"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Top"/>
                </Grid>
            </Border>

            
            
            
           

