<Window x:Class="Androidplayer.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       
        xmlns:svgc="clr-namespace:SharpVectors.Runtime;assembly=SharpVectors.Runtime.Wpf"
        xmlns:converters="http://sharpvectors.codeplex.com/svgc/"


        Title="Sidebar" 
        Height="400" 
        Width="35"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        >
    
    <Border Background="#f0f0f0" 
            BorderBrush="#cccccc" 
            BorderThickness="1"
            CornerRadius="6"
            MouseLeftButtonDown="OnSidebarButtonClick"
            Margin="0">
        
       <StackPanel Margin="5">
            <StackPanel.Resources>
                <Style TargetType="Image">
                    <Setter Property="Margin" Value="0,8"/>
                </Style>
            </StackPanel.Resources>
            
            <!-- <Border Background="#D8D6D6" CornerRadius="50" Height="35" > -->
            <!--     <Image Source="Icons/android.png" Height="25" RenderOptions.BitmapScalingMode="HighQuality"/> -->
            <!-- -->
            <!-- </Border> -->
    
           <Border  CornerRadius="50" Height="35" >
                <Image Source="Icons/android.png" Height="25" RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            
            
            <Border Height="5"/>
            
            <!-- Screenshot with hover effect -->
            <Image Tag="Screenshot"  ToolTip="Screenshot" MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/screenshot.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/screenshot.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Record with hover effect -->
            <Image Tag="Record" ToolTip="Record"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/record.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/record.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Keyboard with hover effect -->
            <Image Tag="Keymap" ToolTip="Keymap menu"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/keyboard.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/keyboard.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Settings with hover effect -->
            <Image Tag="Settings" ToolTip="Settings page"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/settings.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/settings.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Rotate with hover effect -->
            <Image Tag="Rotate" ToolTip="Rotate device"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/rotate.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/rotate.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <Border Height="15"/>
            
            <!-- Back with hover effect -->
            <Image Tag="Back" ToolTip="Back"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/back.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/back.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Home with hover effect -->
            <Image Tag="Home" ToolTip="Home"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/home.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/home.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
            
            <!-- Menu with hover effect -->
            <Image Tag="Recent_apps" ToolTip="Recent apps"  MouseLeftButtonDown="OnSidebarButtonClick" Height="25" RenderOptions.BitmapScalingMode="HighQuality">
                <Image.Style>
                    <Style TargetType="Image" BasedOn="{StaticResource {x:Type Image}}">
                        <Setter Property="Source" Value="Icons/sidebar1/menu.png"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Source" Value="Icons/sidebar2/menu.png"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>
        </StackPanel>
    </Border>
</Window>