

<UserControl x:Class="Androidplayer.Src.Keymap.Keymap_items.Keymap_element_normal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Androidplayer.Src.Keymap.Keymap_items"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             IsHitTestVisible="False"
             Width="60" Height="30"
             
             
             >

    
    <!-- #c4c6c5 -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          
          
         
          Margin="0"
          IsHitTestVisible="True"
          >

        <Border x:Name="MainBorder"
                BorderBrush="#6B7583"
                Background="#AC3C4146"
                BorderThickness="2"
                HorizontalAlignment="Stretch"
                IsHitTestVisible="True"
                CornerRadius="13">
            
            <!-- rgba(129, 119, 93, 1) -->
            
            <!-- Background="#8C294957" -->
            
            <!-- Background="#635a4b" -->

            <Grid Margin="4">
                <!-- Display label (when not editing) -->
                <!-- <TextBlock x:Name="DisplayKey" -->
                <!--            Text="" -->
                <!--            Foreground="White" -->
                <!--            FontSize="12" -->
                <!--            VerticalAlignment="Center" -->
                <!--            HorizontalAlignment="Center" -->
                <!--            Visibility="Visible"/> -->

                
                <TextBlock x:Name="DisplayKey"
                           Text="A"
                           Foreground="White"
                           FontSize="12"
                           SizeChanged="DisplayKey_SizeChanged"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="Visible"
                           TextWrapping="NoWrap" />



               

            
              
            </Grid>
        </Border>
    </Grid>
</UserControl>
