                        <Border Grid.Row="2"
        Height="42"
        Margin="0,0,0,2"
        CornerRadius="0,0,8,8"
        BorderThickness="0,0,0,1"
        Cursor="Hand"
        RenderTransformOrigin="0.5,0.5"
        Background="#F5F7FA"
        BorderBrush="#E0E4EA">

    <!-- Transform for scale animation -->
    <Border.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Border.RenderTransform>

    <!-- − symbol -->
    <TextBlock x:Name="minusText_left"
               Text="−"
               Foreground="#1A73E8"
               FontWeight="Bold"
               FontSize="22"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>

    <!-- ✅ Hover animation triggers -->
    <Border.Triggers>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Animate background color -->
                    <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                    To="#1A73E8"
                                    Duration="0:0:0.1"/>
                    <!-- Animate border color -->
                    <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    To="#1A73E8"
                                    Duration="0:0:0.1"/>
                    <!-- Animate minus text to white -->
                    <ColorAnimation Storyboard.TargetName="minusText_left"
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    To="White"
                                    Duration="0:0:0.1"/>
                    <!-- Scale up -->
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1.05" Duration="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1.05" Duration="0:0:0.08"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>

        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Back to default colors -->
                    <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                    To="#F5F7FA"
                                    Duration="0:0:0.1"/>
                    <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                    To="#E0E4EA"
                                    Duration="0:0:0.1"/>
                    <!-- Animate minus text back to blue -->
                    <ColorAnimation Storyboard.TargetName="minusText_left"
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    To="#1A73E8"
                                    Duration="0:0:0.1"/>
                    <!-- Scale down -->
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1" Duration="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1" Duration="0:0:0.08"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Border.Triggers>
</Border>

                        
                        
                        
                        
                        
                        

