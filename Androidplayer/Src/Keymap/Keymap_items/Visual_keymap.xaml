

<UserControl x:Class="Androidplayer.Src.Keymap.Keymap_items.Visual_keymap"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="180" d:DesignWidth="360"
             Background="Transparent">

    <Grid x:Name="RootGrid" IsHitTestVisible="True" Background="Transparent"
          MouseLeftButtonDown="RootGrid_MouseLeftButtonDown"
          MouseMove="RootGrid_MouseMove"
          MouseLeftButtonUp="RootGrid_MouseLeftButtonUp">

        <!-- Main content with Viewbox for auto-scaling -->
        <Viewbox Stretch="Uniform" Margin="5" StretchDirection="Both">
            <Grid  >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Control (X) -->
                <Border Grid.Column="0"
                        CornerRadius="10"
                        Background="#D8DBE4"
                        BorderBrush="#DADFE6"
                        BorderThickness="2.5"
                        Margin="8"
                        VerticalAlignment="Center"
                        SnapsToDevicePixels="True">
                    <Grid Width="38">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- + -->
                            <RowDefinition Height="Auto"/>   <!-- 25 -->
                            <RowDefinition Height="Auto"/>   <!-- - -->
                            <RowDefinition Height="Auto"/>   <!-- Y -->
                        </Grid.RowDefinitions>

                        
                        
                        
                        <Border Grid.Row="0"
        Margin="0,0,0,3"
        Height="35"
        Cursor="Hand"
        CornerRadius="10,10,7,7"
        BorderThickness="0,0,0,1"
        RenderTransformOrigin="0.5,0.5">

    <!-- Default brushes (important for animating colors) -->
    <Border.Background>
        <SolidColorBrush x:Name="bgBrush_left" Color="#F5F7FA"/>
    </Border.Background>
    <Border.BorderBrush>
        <SolidColorBrush x:Name="borderBrush_left" Color="#E0E4EA"/>
    </Border.BorderBrush>

    <!-- Transform for scale animation -->
    <Border.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1"/>
    </Border.RenderTransform>

    <!-- + symbol -->
    <TextBlock x:Name="plusText_left"
               Text="+"
               Foreground="#1A73E8"
               FontWeight="Bold"
               FontSize="22"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="False"/>

    <!-- ✅ Triggers go directly inside Border.Triggers -->
    <Border.Triggers>

        <!-- Hover -->
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="bgBrush_left"
                                    Storyboard.TargetProperty="Color"
                                    To="#1A73E8"
                                    Duration="0:0:0.1"/>
                    <ColorAnimation Storyboard.TargetName="borderBrush_left"
                                    Storyboard.TargetProperty="Color"
                                    To="#E0E4EA"
                                    Duration="0:0:0.1"/>
                    <ColorAnimation Storyboard.TargetName="plusText_left"
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    To="White"
                                    Duration="0:0:0.1"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1.05" Duration="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1.05" Duration="0:0:0.08"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>

        <!-- Leave -->
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <ColorAnimation Storyboard.TargetName="bgBrush_left"
                                    Storyboard.TargetProperty="Color"
                                    To="#F5F7FA"
                                    Duration="0:0:0.1"/>
                    <ColorAnimation Storyboard.TargetName="borderBrush_left"
                                    Storyboard.TargetProperty="Color"
                                    To="#E0E4EA"
                                    Duration="0:0:0.1"/>
                    <ColorAnimation Storyboard.TargetName="plusText_left"
                                    Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                    To="#1A73E8"
                                    Duration="0:0:0.1"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                     To="1" Duration="0:0:0.08"/>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                     To="1" Duration="0:0:0.08"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>

    </Border.Triggers>
</Border>

                        
                        
