                <Button  FontSize="14" Margin="6" Padding="12,10"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        Background="White" Foreground="#555"  Cursor="Hand"
                        
                        
                        
                        PreviewMouseMove="Button_MouseMove"
                        Tag="Direction"
                        >
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <!-- <TextBlock FontFamily="Segoe MDL2 Assets" Text="" FontSize="22" Margin="0,0,0,4"/> -->
                        
                        <Image Source="K_icons/direction.png" Height="25" 
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,0,4" ></Image>
                        <TextBlock Text="Direction" FontSize="12" Foreground="Black"/>
                    </StackPanel>
                </Button>
                
                <Button Margin="6" FontSize="14" Padding="12,10"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        Background="White" Foreground="#555"  Cursor="Hand"
                        
                        PreviewMouseMove="Button_MouseMove"
                        Tag="Grenade"
                        
                        >
