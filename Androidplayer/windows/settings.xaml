<Grid Grid.Column="2" Margin="0,0,0,0">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>   <!-- for top bar with close button -->
        <RowDefinition Height="*"/>      <!-- for scrollable content -->
        <RowDefinition Height="72"/>     <!-- for footer buttons -->
    </Grid.RowDefinitions>

    <!-- Top bar with image-based close button -->
    <Grid Grid.Row="0" Margin="0,0,0,8" Height="50" HorizontalAlignment="Stretch"  >
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
       
        <Border Grid.Column="0" Background="Transparent" MouseLeftButtonDown="TopBar_MouseLeftButtonDown" >
            
            
            <Image  Source="../Icons/close.png"
                    Margin="0,12,12,0"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Width="22" Height="22"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Cursor="Hand"
                   MouseLeftButtonUp="CloseButton_Click"
                   IsHitTestVisible="True"/>
            
        </Border>
        
        
    </Grid>


    
    
