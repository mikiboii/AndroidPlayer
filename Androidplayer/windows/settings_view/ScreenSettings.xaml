

<UserControl x:Class="Androidplayer.windows.settings_view.ScreenSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Androidplayer.windows.settings_view"
             xmlns:windows="clr-namespace:Androidplayer.windows"
             
             d:DataContext="{d:DesignInstance Type=windows:UISettings, IsDesignTimeCreatable=True}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="500">
    
    <UserControl.Resources>
        <windows:InverseBoolConverter x:Key="InverseBoolConverter"/>
    </UserControl.Resources>


    <!-- Scrollable content card -->
    <Border 
        Background="White"
        CornerRadius="8"
        Padding="24"
        Margin="0,0,0,12"
        BorderBrush="#E8EBF0"
        BorderThickness="1">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Display Resolution -->
                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,16" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource PrimaryBrush}" Text="Screen Resolution" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                        <TextBlock Text="Select the resolution for Android screen mirroring" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/>

                        <!-- <ComboBox Width="180" SelectedItem="{Binding Resolution, Mode=TwoWay}" Margin="0,0,0,8" HorizontalAlignment="Left"> -->
                        <!--     <ComboBoxItem Content="480p"/> -->
                        <!--     <ComboBoxItem Content="720p"/> -->
                        <!--     <ComboBoxItem Content="1080p"/> -->
                        <!--     <ComboBoxItem Content="1280p"/> -->
                        <!--     <ComboBoxItem Content="1K "/> -->
                        <!--     <ComboBoxItem Content="2K"/> -->
                        <!--      -->
                        <!-- </ComboBox> -->
                        
                        <ComboBox Width="180"
                                  
                                  x:Name="resolution_combo"
                                  SelectedItem="{Binding Resolution, Mode=TwoWay}"
                                  
                                  Margin="0,0,0,8"
                                  HorizontalAlignment="Left">
                            <!-- <ComboBoxItem Content="480p"/> -->
                            <!-- <ComboBoxItem Content="720p"/> -->
                            <!-- <ComboBoxItem Content="1080p"/> -->
                            <!-- <ComboBoxItem Content="1280p"/> -->
                            <!-- <ComboBoxItem Content="1K"/> -->
                            <!-- <ComboBoxItem Content="2K"/> -->
                        </ComboBox>

                        <TextBlock Text="* Higher resolutions increase performance cost" 
                                   Foreground="#E36C60" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Frame Rate -->
                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,16" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource PrimaryBrush}" Text="Frame Rate (FPS)" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                        <!-- <TextBlock Text="Set the maximum frame rate for screen mirroring" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/> -->

                        <TextBlock Text="Set the maximum frame rate for screen mirroring. Higher FPS provides a smoother experience."
                                   FontSize="12"
                                   Foreground="#6B6F77"
                                   Margin="0,0,0,12"
                                   TextWrapping="Wrap"/>

                        
                        <!-- <Slider Minimum="1" Maximum="20" Value="8" TickFrequency="1" IsSnapToTickEnabled="True" Width="200" HorizontalAlignment="Left"/> -->
                        <ComboBox x:Name="fps_combo" Width="60" SelectedItem="{Binding FPS, Mode=TwoWay}"  Margin="0,0,0,8" HorizontalAlignment="Left">
                            
                        </ComboBox>
                        
                        <TextBlock Text="Recommended: 20–30 FPS for stable performance" 
                                   Foreground="#E36C60" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Bitrate -->
                <!-- <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,8" BorderBrush="#EEF1F4" BorderThickness="1"> -->
                <!--     <StackPanel> -->
                <!--         <TextBlock Foreground="{DynamicResource PrimaryBrush}" Text="Bitrate (Mbps)" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/> -->
                <!--         <TextBlock Text="Adjust the streaming quality and bandwidth usage" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/> -->
                <!-- -->
                <!--         <Slider Minimum="1" Maximum="20" Value="8" TickFrequency="1" IsSnapToTickEnabled="True" Width="200" HorizontalAlignment="Left"/> -->
                <!--         <TextBlock Text="* Higher bitrate improves quality but increases CPU/network load"  -->
                <!--                    Foreground="#E36C60" FontSize="12" TextWrapping="Wrap"/> -->
                <!--     </StackPanel> -->
                <!-- </Border> -->

                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,8" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource PrimaryBrush}" 
                                   Text="Bitrate (Mbps)" 
                                   FontWeight="Bold" 
                                   FontSize="15" 
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Adjust the streaming quality and bandwidth usage" 
                                   FontSize="12" 
                                   Foreground="#6B6F77" 
                                   Margin="0,0,0,12"/>

                        <!-- Slider + Value -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider x:Name="BitrateSlider"
                                    Minimum="1"
                                    Maximum="20"
                                    Value="{Binding Bitrate, Mode=TwoWay}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Width="120"
                                    HorizontalAlignment="Left"/>
                            <TextBlock Text="{Binding Bitrate, StringFormat='{}{0} Mbps'}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#26292D"/>
                           
                        </StackPanel>

                        <TextBlock Text="* Higher bitrate improves quality but increases CPU/network load" 
                                   Foreground="#E36C60" 
                                   FontSize="12" 
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                
                <!-- Audio Output -->
                <Border CornerRadius="6" 
                        Background="#FFFFFF" 
                        Padding="14" 
                        Margin="0,0,0,16" 
                        BorderBrush="#EEF1F4" 
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource PrimaryBrush}" 
                                   Text="Audio Output"
                                   FontWeight="Bold" 
                                   FontSize="15"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Enable or disable audio forwarding during screen mirroring"
                                   FontSize="12"
                                   Foreground="#6B6F77"
                                   Margin="0,0,0,12"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Vertical" Margin="4,0,0,0">

                            <!-- Audio Enabled -->
                            <RadioButton Content="On"
                                         GroupName="AudioOption"
                                         FontSize="13"
                                         Margin="0,0,0,6"
                                         Foreground="#26292D"
                                         IsChecked="{Binding AudioEnabled, Mode=TwoWay}"/>

                            <!-- Audio Disabled -->
                            <RadioButton Content="Off"
                                         GroupName="AudioOption"
                                         FontSize="13"
                                         Foreground="#26292D"
                                         IsChecked="{Binding AudioEnabled, Converter={StaticResource InverseBoolConverter}, Mode=OneWay}"/>

                        </StackPanel>

                        <TextBlock Text="* Turning off audio reduces bandwidth slightly"
                                   Foreground="#E36C60"
                                   FontSize="12"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"/>

                    </StackPanel>
                </Border>


                
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
