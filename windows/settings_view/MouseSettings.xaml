<UserControl x:Class="Androidplayer.windows.settings_view.MouseSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Androidplayer.windows.settings_view"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
     <!-- Scrollable content card -->
    <Border 
            Background="White"
            CornerRadius="8"
            Padding="24"
            Margin="0,0,0,12"
            BorderBrush="#E8EBF0"
            BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Key mouse unlock -->
                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,16" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <!-- Foreground="#26292D" -->
                        <TextBlock Foreground="{DynamicResource  PrimaryBrush}"  Text="Key mouse unlock" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                        <TextBlock  Text="Global Settings" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/>
                        <CheckBox  Content="Whether to turn on screen center unlock" IsChecked="True" Margin="0,0,0,8"/>
                        <TextBlock Text="* After checking, the position of the mouse after unlocking will always be displayed centered relative to the screen"
                                   Foreground="#E36C60" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Windows System Settings -->
                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,16" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Windows System Settings" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                        <TextBlock Text="Global Settings" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/>
                        <CheckBox Content="Mouse acceleration (improve pointer accuracy)" IsChecked="False" Margin="0,0,0,8"/>
                        <TextBlock Text="* After checking, it will take effect globally in Windows"
                                   Foreground="#E36C60" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Mouse speed -->
                <Border CornerRadius="6" Background="#FFFFFF" Padding="14" Margin="0,0,0,8" BorderBrush="#EEF1F4" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Mouse speed" FontWeight="Bold" FontSize="15" Margin="0,0,0,4"/>
                        <TextBlock Text="Global Settings" FontSize="12" Foreground="#6B6F77" Margin="0,0,0,12"/>
                        <RadioButton Content="Default" IsChecked="True" GroupName="MouseSpeed"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
